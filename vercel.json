{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/generate", "destination": "/api/generate.js" },
    { "source": "/((?!api|assets|icons|manifest|sw).*)", "destination": "/index.html" }
  ]
}
